# Скопировать этот файл в .env на сервере и заполнить значения
# cp .env.production.example .env

# PostgreSQL
POSTGRES_PASSWORD=замените_на_сложный_пароль_минимум_20_символов

# MinIO (S3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=замените_на_сложный_пароль_минимум_20_символов

# JWT — генерируются командой: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Домен (без https://)
DOMAIN=portal.your-company.ru
