# === База данных ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/snark_bot

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === STT (Speech-to-Text) ===
# Провайдер: "faster_whisper" или "yandex_speechkit"
STT_PROVIDER=faster_whisper
# Модель faster-whisper (large-v3, medium, small, base, tiny)
WHISPER_MODEL_SIZE=large-v3
# Yandex SpeechKit
YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=

# === Diarization (pyannote.audio) ===
HF_TOKEN=your-huggingface-token

# === LLM ===
# Провайдер: "yandex_gpt" или "gigachat"
LLM_PROVIDER=yandex_gpt
YANDEX_GPT_API_KEY=
YANDEX_GPT_FOLDER_ID=
# Имя модели для URI gpt://<folder>/<name>/latest (например yandexgpt-lite, yandexgpt)
YANDEX_GPT_MODEL_NAME=yandexgpt-lite
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# NVIDIA NIM (например google/gemma-4-31b-it с https://build.nvidia.com/... )
# LLM_PROVIDER=nvidia_nim
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=google/gemma-4-31b-it

# === 1С:ЗУП ===
ONEC_BASE_URL=http://localhost/zup/odata/standard.odata
ONEC_USERNAME=admin
ONEC_PASSWORD=

# === Безопасность ===
ENCRYPTION_KEY=your-fernet-key-base64
SECRET_KEY=your-secret-key-for-jwt

# === Пути ===
STATIC_DIR=static
MEETINGS_DIR=static/meetings
